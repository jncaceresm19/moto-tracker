{
  "expo": {
    "name": "Moto Tracker",
    "slug": "moto-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "moto-tracker",
    "icon": "./assets/logo.jpeg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#2a2a3a"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.jpeg",
        "backgroundColor": "#2a2a3a"
      },
      "package": "com.anonymous.mototracker"
    },
    "web": {
      "favicon": "./assets/logo.jpeg"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ]
  }
}
