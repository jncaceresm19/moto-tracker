{
  "name": "@moto-tracker/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Moto Tracker backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "express": "^5.1.0",
    "drizzle-orm": "^0.44.0",
    "better-sqlite3": "^11.9.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "helmet": "^8.1.0",
    "zod": "^3.25.0",
    "dotenv": "^16.5.0",
    "@moto-tracker/shared": "*"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "tsx": "^4.19.4",
    "vitest": "^3.2.1",
    "@vitest/coverage-v8": "^3.2.1",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.27.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0"
  }
}
