# Server
PORT=3001

# Database
DATABASE_URL=./dev.db

# JWT — min 256-bit (32 bytes)
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-bytes
JWT_REFRESH_SECRET=change-me-to-a-different-secure-random-string

# Google OAuth (Web client ID for Expo)
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
